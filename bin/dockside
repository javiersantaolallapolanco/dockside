#!/bin/sh
set -eu

SELF_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
DOCKSIDE_ROOT="$(CDPATH= cd -- "$SELF_DIR/.." && pwd)"
export DOCKSIDE_ROOT

. "$DOCKSIDE_ROOT/core/bootstrap/bootstrap.sh"
. "$DOCKSIDE_ROOT/core/command/command.sh"

bootstrap_init

CMD="${1:-help}"

case "$CMD" in

help|-h|--help)
cat <<HELP
Dockside

Usage

  dockside version
  dockside doctor

  dockside platform <command>
  dockside app <command>

HELP
;;

version)
    cat "$DOCKSIDE_ROOT/VERSION"
;;

doctor)
    command_run platform doctor
;;

platform)
    shift
    command_run platform "${1:-}"
;;

app)
    shift
    command_run app "${1:-}"
;;

*)
    printf '%s\n' "Unknown command: $CMD" >&2
    exit 1
;;

esac
