#!/bin/sh
set -eu

SELF_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
DOCKSIDE_ROOT="$(CDPATH= cd -- "$SELF_DIR/.." && pwd)"
export DOCKSIDE_ROOT

. "$DOCKSIDE_ROOT/core/bootstrap/bootstrap.sh"

bootstrap_init

CMD="${1:-help}"

show_help() {
cat <<HELP
Dockside

Usage

  dockside help
  dockside version
  dockside doctor

HELP
}

case "$CMD" in

help|-h|--help)
    show_help
    ;;

version)
    cat "$DOCKSIDE_ROOT/VERSION"
    ;;

doctor)
    exec "$DOCKSIDE_ROOT/core/platform/doctor/run.sh"
    ;;

*)
    echo "Unknown command: $CMD" >&2
    exit 1
    ;;
esac
