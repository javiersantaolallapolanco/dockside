#!/bin/sh
set -eu

SELF_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
DOCKSIDE_HOME=$(CDPATH= cd -- "$SELF_DIR/.." && pwd)
export DOCKSIDE_HOME

CMD="${1:-help}"
[ "$#" -gt 0 ] && shift

case "$CMD" in
  init|start|stop|status|use|doctor|logs)
    exec "$DOCKSIDE_HOME/scripts/commands/$CMD.sh" "$@"
    ;;
  version)
    cat "$DOCKSIDE_HOME/VERSION"
    ;;
  help|-h|--help|"")
    cat <<HELP
Dockside 1.0

Commands:
  init
  start
  stop
  status
  use <app>
  logs [stack]
  doctor
  version
HELP
    ;;
  *)
    echo "Unknown command: $CMD" >&2
    exit 1
    ;;
esac
